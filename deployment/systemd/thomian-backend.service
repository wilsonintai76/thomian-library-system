[Unit]
Description=Gunicorn instance to serve Thomian Library Backend
After=network.target

[Service]
User=sysadmin
Group=www-data
WorkingDirectory=/home/sysadmin/Projects/thomian-library-system
ExecStart=/home/sysadmin/Projects/thomian-library-system/venv/bin/gunicorn \
          --access-logfile - \
          --workers 3 \
          --bind unix:/home/sysadmin/Projects/thomian-library-system/thomian.sock \
          backend.wsgi:application

[Install]
WantedBy=multi-user.target
