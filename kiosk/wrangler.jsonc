{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "thomian-kiosk",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-01-27",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "r2_buckets": [
    {
      "binding": "NEXT_INC_CACHE_R2_BUCKET",
      "bucket_name": "thomian-lib"
    }
  ]
}
